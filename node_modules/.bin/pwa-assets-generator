#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/opt/zycloud/calendar-remark/node_modules/.pnpm/@vite-pwa+assets-generator@0.2.2/node_modules/@vite-pwa/assets-generator/node_modules:/opt/zycloud/calendar-remark/node_modules/.pnpm/@vite-pwa+assets-generator@0.2.2/node_modules:/opt/zycloud/calendar-remark/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/opt/zycloud/calendar-remark/node_modules/.pnpm/@vite-pwa+assets-generator@0.2.2/node_modules/@vite-pwa/assets-generator/node_modules:/opt/zycloud/calendar-remark/node_modules/.pnpm/@vite-pwa+assets-generator@0.2.2/node_modules:/opt/zycloud/calendar-remark/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../@vite-pwa/assets-generator/bin/pwa-assets-generator.mjs" "$@"
else
  exec node  "$basedir/../@vite-pwa/assets-generator/bin/pwa-assets-generator.mjs" "$@"
fi
