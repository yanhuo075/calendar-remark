#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/opt/zycloud/calendar-remark/node_modules/.pnpm/vitest@1.2.2_@types+node@24.10.1_terser@5.44.1/node_modules/vitest/node_modules:/opt/zycloud/calendar-remark/node_modules/.pnpm/vitest@1.2.2_@types+node@24.10.1_terser@5.44.1/node_modules:/opt/zycloud/calendar-remark/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/opt/zycloud/calendar-remark/node_modules/.pnpm/vitest@1.2.2_@types+node@24.10.1_terser@5.44.1/node_modules/vitest/node_modules:/opt/zycloud/calendar-remark/node_modules/.pnpm/vitest@1.2.2_@types+node@24.10.1_terser@5.44.1/node_modules:/opt/zycloud/calendar-remark/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../vitest/vitest.mjs" "$@"
else
  exec node  "$basedir/../vitest/vitest.mjs" "$@"
fi
